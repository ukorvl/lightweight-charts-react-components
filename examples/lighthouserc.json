{
  "ci": {
    "collect": {
      "startServerCommand": "npm run preview",
      "startServerReadyPattern": "Local:",
      "url": ["http://localhost:4173/", "http://localhost:4173/terminal"],
      "numberOfRuns": 1,
      "settings": {
        "chromeFlags": "--headless --no-sandbox --disable-gpu --disable-dev-shm-usage"
      }
    },
    "assert": {
      "assertions": {
        "accesskeys": "error",
        "aria-allowed-attr": "error",
        "aria-allowed-role": "error",
        "aria-command-name": "error",
        "aria-conditional-attr": "error",
        "aria-deprecated-role": "error",
        "aria-dialog-name": "error",
        "aria-hidden-body": "error",
        "aria-hidden-focus": "error",
        "aria-input-field-name": "error",
        "aria-meter-name": "error",
        "aria-progressbar-name": "error",
        "aria-prohibited-attr": "error",
        "aria-required-attr": "error",
        "aria-required-children": "error",
        "aria-required-parent": "error",
        "aria-roles": "error",
        "aria-text": "error",
        "aria-toggle-field-name": "error",
        "aria-tooltip-name": "error",
        "aria-treeitem-name": "error",
        "aria-valid-attr-value": "error",
        "aria-valid-attr": "error",
        "button-name": "error",
        "bypass": "error",
        "color-contrast": "off",
        "definition-list": "error",
        "dlitem": "error",
        "document-title": "error",
        "duplicate-id-aria": "error",
        "form-field-multiple-labels": "error",
        "frame-title": "error",
        "heading-order": "error",
        "html-has-lang": "error",
        "html-lang-valid": "error",
        "html-xml-lang-mismatch": "error",
        "image-alt": "error",
        "image-redundant-alt": "error",
        "input-button-name": "error",
        "input-image-alt": "error",
        "label": "error",
        "link-in-text-block": "off",
        "link-name": "error",
        "list": "error",
        "listitem": "error",
        "meta-refresh": "error",
        "meta-viewport": "error",
        "object-alt": "error",
        "select-name": "error",
        "skip-link": "error",
        "tabindex": "error",
        "table-duplicate-name": "error",
        "target-size": "error",
        "td-headers-attr": "error",
        "th-has-data-cells": "error",
        "valid-lang": "error",
        "video-caption": "error",
        "focusable-controls": "off",
        "interactive-element-affordance": "off",
        "logical-tab-order": "off",
        "visual-order-follows-dom": "off",
        "focus-traps": "off",
        "managed-focus": "off",
        "use-landmarks": "off",
        "offscreen-content-hidden": "off",
        "custom-controls-labels": "off",
        "custom-controls-roles": "off",
        "empty-heading": "error",
        "identical-links-same-purpose": "error",
        "landmark-one-main": "error",
        "label-content-name-mismatch": "error",
        "table-fake-caption": "error",
        "td-has-header": "error",
        "is-on-https": "off",
        "redirects-http": "off",
        "geolocation-on-start": "error",
        "notification-on-start": "error",
        "csp-xss": "error",
        "has-hsts": "off",
        "origin-isolation": "off",
        "clickjacking-mitigation": "off",
